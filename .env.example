# Application
APP_NAME=NPF-Development
APP_ENV=development
DEBUG=true

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Frontend
VITE_API_URL=http://localhost:8000

# Database (SQLite for development)
DATABASE_URL=sqlite+aiosqlite:///./db/npf.db

# PostgreSQL (for production)
# DATABASE_URL=postgresql+asyncpg://npf:npf_secure_password@postgres:5432/npf_db
POSTGRES_USER=npf
POSTGRES_PASSWORD=npf_secure_password
POSTGRES_DB=npf_db
POSTGRES_PORT=5432

# ChromaDB
CHROMA_PERSIST_DIRECTORY=./chroma_db

# Ollama (for Docker use http://ollama:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your-api-key-here

# Timeweb AI (Cloud AI provider)
TIMEWEB_AI_TOKEN=your-timeweb-token-here
TIMEWEB_AGENT_ID=your-agent-id-here

# LLM Provider (ollama, anthropic, or timeweb)
CHAT_PROVIDER=timeweb

# JWT Auth
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# File Upload
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=.xlsx,.xls,.csv,.pdf,.docx,.txt

# NPF Server Production Configuration
# Copy to .env.server and fill in the values

# PostgreSQL (REQUIRED - set strong password!)
POSTGRES_USER=npf
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=npf_db

# Security (REQUIRED - generate with: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_RANDOM_SECRET

# JWT Settings (optional)
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440  # 24 hours default

# Initial Admin User (created on first start, leave empty to skip)
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ========== AI PROVIDERS ==========

# Timeweb Cloud AI (RAG with OpenSearch knowledge base)
TIMEWEB_AI_TOKEN=your-timeweb-jwt-token
TIMEWEB_AGENT_ID=your-agent-uuid

# DeepSeek API (direct chat without RAG, cheaper alternative)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Anthropic Claude API (fallback for chat, required for OCR)
ANTHROPIC_API_KEY=sk-ant-api03-...

# LLM Provider for chat (timeweb, ollama, or anthropic)
CHAT_PROVIDER=timeweb

# Ollama (optional, for local embeddings)
# OLLAMA_BASE_URL=http://localhost:11434

# ========== OPTIONAL ==========

# Custom ports
# FRONTEND_PORT=80
# BACKEND_PORT=8000
